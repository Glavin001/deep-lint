{
  "name": "deep-lint",
  "version": "0.1.0",
  "description": "Composable multi-stage lint rules — from pattern matching to type checking to LLM review.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "deep-lint": "./dist/cli.js"
  },
  "files": [
    "dist",
    "rules"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "lint",
    "ast-grep",
    "llm",
    "pipeline",
    "code-review",
    "static-analysis"
  ],
  "license": "MIT",
  "dependencies": {
    "@ast-grep/napi": "^0.42.0",
    "ai": "^6.0.0",
    "chalk": "^5.4.0",
    "commander": "^14.0.0",
    "glob": "^11.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
